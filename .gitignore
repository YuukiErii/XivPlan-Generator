# Python cache
__pycache__/
*.py[cod]

# Local virtual environments and package caches
.venv/
venv/
env/
.mypy_cache/
.pytest_cache/

# Node / frontend build outputs if local XivPlan tooling is staged here later
node_modules/
dist/
release/
*.zip

# Generated guide exports and bulky local outputs
outputs/
exports/
*.docx
*.pdf
*.pptx

# Runtime pipeline outputs. Keep source fixtures, scripts, docs, and a few tracked
# lightweight examples; generated PNG/DOCX/PDF/report trees stay local.
artifacts/**
!artifacts/
!artifacts/README.md
!artifacts/ultimate-yokai-star-dance/
!artifacts/ultimate-yokai-star-dance/README.md
!artifacts/ultimate-yokai-star-dance/change-log.md
!artifacts/ultimate-yokai-star-dance/raw-notes/
!artifacts/ultimate-yokai-star-dance/raw-notes/*.md

# Local secrets and machine-specific config
.env
.env.*
*.local

# Keep curated lightweight generated examples, but ignore ad-hoc build folders
build/
tmp/
temp/
